# News Monkey Configuration
# Copy to .env and fill in values. Environment variables override these.

# --- API Keys (secrets) ---
KALSHI_API_KEY=
NEWSAPI_KEY=

# --- Ollama LLM ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_TIMEOUT=30

# --- Data paths (default: ./data/) ---
# NEWS_MONKEY_DB=./data/news_monkey.db
# NEWS_MONKEY_DATA_DIR=./data

# --- Poll intervals (seconds) ---
# RSS_POLL_INTERVAL=300
# POLYMARKET_POLL_INTERVAL=600
# SOCIAL_POLL_INTERVAL=300
# CALLSHEET_POLL_INTERVAL=600
# NEWSAPI_POLL_INTERVAL=600

# --- API URLs ---
# POLYMARKET_API_URL=https://gamma-api.polymarket.com
# CALLSHEET_API_URL=https://callsheet.com/api/v1
# KALSHI_API_URL=https://trading-api.kalshi.com/trade-api/v2

# --- Social media RSS bridges ---
# TIKTOK_RSS_URL=https://rsshub.app/tiktok/trend/en
# INSTAGRAM_RSS_URL=https://rsshub.app/instagram/explore

# --- Custom feeds/subreddits (comma-separated) ---
# NEWS_MONKEY_FEEDS=
# NEWS_MONKEY_SUBREDDITS=

# --- Service config ---
# ENABLE_INGESTION=true
# SERVICE_ROLE=all
